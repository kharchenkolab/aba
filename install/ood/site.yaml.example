# /cluster/aba/site.yaml — dev OOD stack (mock, VBC-flavored).
# Read by aba-preflight (node) AND form.yml.erb (dashboard). The ONE file that
# describes this deployment; the OOD app + ABA loader are otherwise generic.
site:
  name: "Vienna BioCenter (dev)"
  install_id: "vbc-dev"
  docs_url: "https://example.org/aba/docs"

# How the backend runs on a node. Omit `image` to bind-mount the repo+venv (dev /
# direct nodes). With a SIF the node launches from the image; base_dir/tools_dir
# are the shared conda + R base mounts a SLIM image needs (omit them for fat).
image:
  sif: /cluster/aba/aba.sif
  # base_dir:  /cluster/aba/base          # slim only — mounted at /opt/aba-venv
  # tools_dir: /cluster/aba/base/tools    # slim only — mounted at /opt/aba-envs/tools
  # release_root: /cluster/aba            # VERSIONED slim deploy (RELEASE_MODE=1 ./deploy.sh):
  #   sets it and the launcher IGNORES sif/base_dir/tools_dir above — it pins the session to
  #   <release_root>/current's release and derives sif/env from it (exports ABA_RELEASE_ID). An
  #   admin promoting a new release doesn't disturb running sessions. See misc/slim_sif_deploy.md.

# Background-job offload. submitter=slurm lets the agent sbatch long runs as their
# OWN Slurm jobs (own resources, survive the session); hpc_config maps the agent's
# size estimate to your partitions/QOS (same schema as cluster_personal.md §"Tune
# your cluster's queues"). Omit this section to keep background work in-process on
# the session's allocated node.
jobs:
  submitter: slurm
  hpc_config: /cluster/aba/hpc.yaml

scopes:
  # Recipes are now BAKED into the SIF as the system scope (ABA_SYSTEM_BUNDLE).
  # This institution bundle is OPTIONAL — site-wide recipe/policy additions the
  # admin changes WITHOUT rebuilding the image; omit it to use only the baked pack.
  institution:
    bundle_path: /cluster/aba/installation   # optional, layered over the baked pack
  group:
    enabled: true
    root_path: /groups/{group}/aba     # ABA's area inside the group share
    bundle_subdir: bundle              # the lab bundle (recipes/rules) — layers over system+institution
    # ENROLLMENT GATE. false (recommended for a hand-held pilot): a group can
    # launch only after an admin ENROLLS it — i.e. /groups/<group>/aba exists with
    # the .aba-workspace marker (use the enroll-group helper). Un-enrolled groups
    # are blocked at preflight (and hidden from the launch form). Set true to
    # instead auto-provision a workspace on a group's first launch (no gate).
    auto_create_skeleton: false
    skeleton_template: /cluster/aba/group-skeleton
    # not_enrolled_message: "Email aba-admin@your.org to join the ABA pilot."  # optional override
  user:
    # VBC: everything per-user UNDER the group. state_dir = the user's runtime
    # (projects/runs/db); envs default to <state_dir>/envs (per-user global +
    # project growth over the shared base). Non-group installs point at {home}.
    state_dir: /groups/{group}/aba/users/{user}
    # envs_dir: /groups/{group}/aba/users/{user}/envs   # default: <state_dir>/envs

# Shared reference store tiers (genomes, indices, annotations — refs.md §3.3).
# The backend reads these paths directly via its scope resolver (ABA_SITE_CONFIG);
# aba-preflight creates the GROUP dir group-writable + setgid, owned by the lab
# group, so members share refs and new files inherit the group. The institution
# tier is optional + curator-managed (read-only to users); a regular user's
# register falls back to their personal store and suggests a promote.
refs:
  group: /groups/{group}/aba/refs
  # institution: /cluster/aba/refs        # optional; curator writes, everyone reads

# Compute-site management. On a SHARED deployment users should not add/reconfigure
# their own compute machines — set self_service:false so Settings → Compute shows the
# deployment's machines READ-ONLY, the /api/compute management endpoints 403, and the
# Guide's site tools refuse to connect one. Omit (or true) for a self-managed install.
# compute:
#   self_service: false

group_resolution:
  source: ood_form
  fallback: unix_primary_group
  candidate_groups: unix_groups

credentials:
  # Prefer OAuth: user_oauth picks up a seeded refreshable store
  # ({home}/.aba/oauth.json — auto-renewing) or the Claude Code CLI store
  # (~/.claude/.credentials.json). Falls back to a saved key, the lab-shared
  # key, then a form paste (which auto-detects sk-ant-oat OAuth vs sk-ant-api).
  order: [user_oauth, user_saved, group_shared, user_form_paste]
  user_key_path: /groups/{group}/aba/users/{user}/.aba/credentials.json   # per-user, 0700 (umask 077)
  group_key_path: /groups/{group}/aba/.credentials.json     # lab-shared key (apikey or oauth)
  on_missing: prompt_at_launch

fallbacks:
  no_group_bundle: use_institution_only
  no_institution_bundle: use_system_only
  no_group_root: block_not_enrolled
  malformed_group_bundle: warn_and_skip

ui_text:
  form_intro: "Your enrolled ABA groups (✓). Group not listed? Ask your admin to enroll it."
  enroll_contact: "your ABA admin"     # shown to users whose group isn't enrolled (form + preflight)
  no_group_key_help: "Paste your Anthropic API key, or save one to your lab's ABA folder."
