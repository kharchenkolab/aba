#!/usr/bin/env bash
# Launch the REAL ABA backend on this compute node, served on $host:$port and
# reverse-proxied by OOD at /rnode/$host/$port/.
#
# ABA_RUNTIME_DIR + ABA_ENVS_DIR (both PER-USER, under /groups/<group>/aba/users/<user>/)
# are set by before.sh.erb from site.yaml via aba-preflight. Only the frontend dist
# is per-session here (the proxy prefix differs each launch). If ABA_SIF is set
# (site.yaml image.sif) the backend runs FROM the image; otherwise from the
# bind-mounted repo + venv (dev / direct nodes).
set -x

ABA=/home/pkharchenko/aba/aba
VENV=/home/pkharchenko/aba/aba_runtime/.venv

export HOME="${ABA_RUNTIME_DIR}/.home"; mkdir -p "$HOME"
export ABA_MODEL="${ABA_MODEL:-claude-haiku-4-5-20251001}"

# ABA_HOME = the per-user store, incl. the refreshable OAuth token store
# ($ABA_HOME/oauth.json). Set explicitly so the OAuth auto-refresh tier activates.
export ABA_HOME="${ABA_HOME:-${HOME}/.aba}"; mkdir -p "$ABA_HOME"

# --- per-session SPA build: bake this session's OOD reverse-proxy prefix into a
# private writable copy (the dist ships /__OOD_PREFIX__/ placeholders). Source it
# from the image (SIF) or the bind-mounted repo.
if [ -n "${ABA_SIF:-}" ]; then
  apptainer exec --bind "${PWD}:${PWD}" "${ABA_SIF}" cp -r /opt/aba/frontend-dist "${PWD}/dist"
else
  cp -r "${ABA}/frontend/dist" "${PWD}/dist"
fi
find "${PWD}/dist" -type f \( -name '*.html' -o -name '*.js' -o -name '*.css' -o -name '*.svg' \) \
  -exec sed -i "s|__OOD_PREFIX__|rnode/${host}/${port}|g" {} +
export ABA_FRONTEND_DIST="${PWD}/dist"

echo "ABA: ${host}:${port} | runtime=${ABA_RUNTIME_DIR} | envs=${ABA_ENVS_DIR} | sif=${ABA_SIF:-none}"

# --- Clean shutdown: recursively kill uvicorn's WHOLE descendant tree on stop ---
# (the OOD wrapper only pkill -P's direct children, so kernels would orphan ->
# <defunct> zombies and the Slurm job hangs in CG). Scoped to THIS job's tree, so
# it's multi-user safe. graceful TERM first, then KILL any stragglers.
killtree() {                      # killtree <pid> <signal>
  local _pid="$1" _sig="$2" _c
  for _c in $(pgrep -P "$_pid" 2>/dev/null); do killtree "$_c" "$_sig"; done
  kill -"$_sig" "$_pid" 2>/dev/null || true
}

if [ -n "${ABA_SIF:-}" ]; then
  # --- run FROM the image (production: setuid apptainer on the node) ---
  # --containall so the host $HOME doesn't shadow the baked /opt; forward ABA's
  # resolved runtime env + bind the cluster scope mounts. The image's runscript
  # starts uvicorn on $ABA_PORT inside the container.
  # /groups + /cluster/aba also cover the reference-store tiers (refs.md): the
  # group refs at /groups/<group>/aba/refs and the optional institution refs at
  # /cluster/aba/refs are already inside these mounts, and ABA_SITE_CONFIG +
  # ABA_GROUP are forwarded below — so the backend resolves + reads refs with no
  # refs-specific bind or env. (If a site puts institution refs OUTSIDE
  # /cluster/aba, add a --bind for it here.)
  binds=( --bind "${PWD}/dist" )
  [ -d /groups ] && binds+=( --bind /groups )
  # The share root (site.yaml, image, skeleton, institution bundle + its refs tier).
  # Derived, not hardcoded: a site may root the deployment anywhere its nodes can read.
  _share="${ABA_SHARE:-$(dirname "${ABA_SITE_CONFIG:-/cluster/aba/site.yaml}")}"
  [ -d "${_share}" ] && binds+=( --bind "${_share}" )
  # site.yaml `binds:` (→ ABA_EXTRA_BINDS): any further host paths the deployment needs
  # visible under --containall — e.g. a group/user tree outside /groups.
  for b in ${ABA_EXTRA_BINDS:-}; do [ -e "$b" ] && binds+=( --bind "$b" ); done
  # slim image: mount the shared conda base (+ R base) the image expects at /opt.
  [ -n "${ABA_BASE_DIR:-}" ] && binds+=( --bind "${ABA_BASE_DIR}:/opt/aba-venv" )
  [ -n "${ABA_TOOLS_DIR:-}" ] && [ -d "${ABA_TOOLS_DIR}" ] && binds+=( --bind "${ABA_TOOLS_DIR}:/opt/aba-envs/tools" )
  envs=( --env "ABA_FRONTEND_DIST=${PWD}/dist" --env "ABA_PORT=${port}" )
  for v in ABA_RUNTIME_DIR ABA_ENVS_DIR ABA_SITE_CONFIG ABA_GROUP ABA_MODEL ABA_HOME \
           ABA_SHARE ABA_RELEASE_ID \
           ABA_NEXTFLOW_MODULE ABA_NEXTFLOW_PROFILES ABA_NEXTFLOW_CONFIG ABA_NEXTFLOW_CACHEDIR \
           ANTHROPIC_API_KEY ABA_LLM_CREDENTIAL CLAUDE_CODE_OAUTH_TOKEN; do
    eval "_v=\${$v:-}"; [ -n "${_v}" ] && envs+=( --env "$v=${_v}" )
  done

  # --- Slurm offload plumbing: expose the host scheduler to the --containall
  # backend so it can `sbatch` background jobs. Bind the client binaries + the
  # libslurm plugin dir + SLURM_CONF + the munge socket/lib, plus a SYNTHESIZED
  # passwd/group holding the runtime user + slurm/munge (via getent — LDAP users
  # aren't in the image passwd and containall has no SSSD). Host RHEL binaries run
  # on the image's newer glibc (backward-compatible). No-op off Slurm.
  # NB `sacctmgr` is in the list, not just for symmetry: hpc_config.qos_account_live()
  # shells out to it to discover the user's QOS + account + each QOS's MaxWall cap.
  # Without it bound, discovery returns empty inside the SIF, jobs fall back to the
  # cluster's DEFAULT QOS + uncapped walltime, and a long request (e.g. the 24h
  # nextflow head) is rejected QOSMaxWallDurationPerJobLimit. Binding it lets the
  # slim SIF self-configure QOS/account on any accounting cluster — no hpc.yaml.
  if command -v sbatch >/dev/null 2>&1; then
    for b in sbatch squeue scancel sacct sacctmgr sinfo scontrol salloc srun; do
      p=$(command -v "$b" 2>/dev/null) && binds+=( --bind "$p" )
    done
    sld=$(ldd "$(command -v sbatch)" 2>/dev/null | awk '/libslurm/{print $3}' | head -1)
    [ -n "$sld" ] && binds+=( --bind "$(dirname "$sld")" )
    scf="${SLURM_CONF:-/etc/slurm/slurm.conf}"
    [ -f "$scf" ] && { binds+=( --bind "$(dirname "$scf")" ); envs+=( --env "SLURM_CONF=$scf" ); }
    for m in /run/munge /var/run/munge; do [ -S "$m/munge.socket.2" ] && binds+=( --bind "$m" ); done
    ml=$(ldconfig -p 2>/dev/null | awk '$1=="libmunge.so.2"{print $NF; exit}')
    [ -n "$ml" ] && binds+=( --bind "$ml" )
    nss="${PWD}/nss"; mkdir -p "$nss"
    getent passwd "$(id -un)" slurm munge root nobody > "$nss/passwd" 2>/dev/null
    getent group  "$(id -gn)" slurm munge root nobody   > "$nss/group"  2>/dev/null
    [ -s "$nss/passwd" ] && binds+=( --bind "$nss/passwd:/etc/passwd" )
    [ -s "$nss/group" ]  && binds+=( --bind "$nss/group:/etc/group" )
  fi

  # --- Option B offload: run offloaded jobs BARE on the compute node (misc/
  # slim_sif_deploy.md). A background Slurm job runs OUTSIDE any container, where
  # /opt/aba-venv + /opt/aba/backend (the in-image paths the backend would bake
  # into job.sh) don't exist. Point offloaded jobs at the shared-FS base venv +
  # a copy of the backend extracted from the image (cached per release under the
  # user runtime, on a compute-node-visible FS). slurm_submitter._offload_runtime
  # reads ABA_OFFLOAD_PYTHON / ABA_OFFLOAD_BACKEND_DIR; unset → native, unchanged.
  if [ -n "${ABA_BASE_DIR:-}" ] && [ -x "${ABA_BASE_DIR}/bin/python" ]; then
    obd="${ABA_RUNTIME_DIR}/.offload/${ABA_RELEASE_ID:-static}/backend"
    if [ ! -d "$obd" ]; then
      mkdir -p "$(dirname "$obd")"
      apptainer exec --bind "$(dirname "$obd")":"$(dirname "$obd")" "${ABA_SIF}" \
        cp -a /opt/aba/backend "$obd.$$" 2>/dev/null && mv -f "$obd.$$" "$obd" 2>/dev/null || true
    fi
    envs+=( --env "ABA_OFFLOAD_PYTHON=${ABA_BASE_DIR}/bin/python" )
    if [ -d "$obd" ]; then envs+=( --env "ABA_OFFLOAD_BACKEND_DIR=${obd}" )
    else echo "ABA: WARNING offload backend not staged ($obd) — background Slurm jobs may fail"; fi
  fi

  # --- Host environment-modules plumbing (site.yaml `modules:` → ABA_MODULE_* in
  # aba-env.sh): bind the cluster's Lmod + modulefiles + tool trees so IN-SESSION
  # `module load` works inside the SIF. Only sound when the base image's glibc matches
  # the nodes' (build.sh enforces) — then these host EL libs are ABI-compatible; the
  # backend's core/exec/modules.py then finds LMOD_PKG/init/bash (bound) and activates.
  # Resolve on THIS node: source the init for MODULEPATH/LMOD_*, ldconfig the libs.
  # No-op when unset. (Offloaded Slurm jobs load modules natively on the bare node.)
  if [ -n "${ABA_MODULE_INIT:-}" ] && [ -f "${ABA_MODULE_INIT}" ]; then
    ( . "${ABA_MODULE_INIT}" >/dev/null 2>&1
      for v in MODULEPATH MODULESHOME LMOD_CMD LMOD_DIR LMOD_PKG LMOD_ROOT LMOD_SYSTEM_DEFAULT_MODULES \
               LMOD_RC LMOD_PACKAGE_PATH LMOD_SYSHOST; do
        eval "_x=\${$v:-}"; [ -n "$_x" ] && echo "$v=$_x"; done ) > "${PWD}/.modenv"
    while IFS='=' read -r _k _v; do [ -n "$_v" ] && envs+=( --env "${_k}=${_v}" ); done < "${PWD}/.modenv"
    for b in ${ABA_MODULE_BINDS:-}; do [ -e "$b" ] && binds+=( --bind "$b" ); done
    _hostlib=0
    for l in ${ABA_MODULE_LIBS:-}; do
      f=$(ldconfig -p 2>/dev/null | awk -v L="$l" '$1==L{print $NF; exit}')
      [ -n "$f" ] && { binds+=( --bind "$f:/opt/hostlibs/$l" ); _hostlib=1; }
    done
    [ "$_hostlib" = 1 ] && envs+=( --env "LD_LIBRARY_PATH=/opt/hostlibs" )
  fi

  apptainer run --containall "${binds[@]}" "${envs[@]}" "${ABA_SIF}" &
  UV=$!
else
  # --- run from the bind-mounted repo + venv (dev / direct nodes) ---
  export ABA_TOOLS_DIR="${ABA_TOOLS_DIR:-$(dirname "${VENV}")/envs/tools}"
  cd "${ABA}/backend"
  "${VENV}/bin/python" -m uvicorn main:app --host 0.0.0.0 --port "${port}" &
  UV=$!
fi

shutdown() {
  echo "ABA: shutting down (pid ${UV}) ..."
  killtree "$UV" TERM
  for _ in $(seq 1 8); do kill -0 "$UV" 2>/dev/null || break; sleep 1; done
  killtree "$UV" KILL
}
trap shutdown TERM INT EXIT
wait "$UV"
