<%#
  Session-card info view. Renders in the BatchConnect::Session binding (self =
  session), so `staged_root` is available here (unlike view.html.erb). Reads the
  status.yaml aba-preflight wrote and shows the scope/credential checklist
  (site-config.md surface 2).
%>
<%
  status = {}
  begin
    sf = staged_root.join("status.yaml")
    status = (YAML.safe_load(File.read(sf)) || {}) if File.exist?(sf)
  rescue => _e
    status = {}
  end
%>
<% if status.is_a?(Hash) && status["scopes"] %>
**ABA workspace<%= status["group"] ? " — #{status["group"]} lab" : "" %>**

<% status["scopes"].each do |name, info| %>
- <%= info["state"].to_s.start_with?("ok", "skeleton", "created") ? "✓" : "○" %> **<%= name.capitalize %>** — <%= info["detail"] %>
<% end %>
- <%= status.dig("credentials", "resolved") ? "✓" : "⚠" %> **Credentials** — <%= status.dig("credentials", "resolved") ? "using #{status.dig("credentials","source").to_s.tr("_"," ")}" : "no key — will prompt in chat" %>
<% (status["warnings"] || []).each do |w| %>
- ⚠ <%= w %>
<% end %>
<% end %>
<%# Version footer — DEPLOYMENT-SIDE (no SIF rebuild). The release is the one preflight
    PINNED for THIS session (ABA_RELEASE_ID in aba-env.sh, more correct than reading
    `current` at render time — an admin may have promoted since launch); env stacks come
    from the publish-tree catalog (ABA_WEFT_PUBLISH_TREE). App + envs version independently,
    so both are shown: release in full (incl. commit), env versions date-only for compactness.
    (catalog.json is parsed with YAML — JSON is a YAML subset — to avoid a `require 'json'`.) %>
<%
  _release = nil; _tree = nil
  begin
    ef = staged_root.join("aba-env.sh")
    File.read(ef).each_line do |ln|
      _release = $1.strip.gsub(/\A['"]|['"]\z/, "") if ln =~ /^export ABA_RELEASE_ID=(.*)$/
      _tree    = $1.strip.gsub(/\A['"]|['"]\z/, "") if ln =~ /^export ABA_WEFT_PUBLISH_TREE=(.*)$/
    end if File.exist?(ef)
  rescue => _e
  end
  _envs = []
  begin
    cat = YAML.safe_load(File.read(File.join(_tree, "catalog.json"))) if _tree
    ((cat || {})["envs"] || {}).each do |n, i|
      v = (i["latest"] || "").to_s
      _envs << "#{n} #{v.rpartition('-').first}" unless v.empty?
    end
  rescue => _e
  end
  _bits = []
  _bits << "aba release #{_release}" if _release && !_release.empty?
  _bits << "envs: #{_envs.join(", ")}" unless _envs.empty?
%>
<% unless _bits.empty? %>

<small style="color:#888"><%= _bits.join(" · ") %></small>
<% end %>
