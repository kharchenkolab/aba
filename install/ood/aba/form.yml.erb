<%-
  # ── Preflight at form-render time, driven by /cluster/aba/site.yaml ──
  # List ONLY the launching user's own unix groups that are ENROLLED in ABA —
  # i.e. /groups/<group>/aba carries the .aba-workspace marker (the SAME signal
  # aba_preflight gates on). Unenrolled groups are omitted so a user can't launch
  # a session preflight would just block. All paths come from site.yaml.
  require 'yaml'; require 'etc'
  # Deployment share root. deploy.sh rewrites this default for the site; an exported
  # ABA_SITE_CONFIG still wins.
  site_default = '/cluster/aba/site.yaml'
  site = (YAML.safe_load(File.read(ENV['ABA_SITE_CONFIG'] || site_default)) rescue nil) || {}
  gcfg = (site['scopes'] || {})['group'] || {}
  ucfg = (site['scopes'] || {})['user']  || {}
  # GPU field — shown unless the site disables it (`form: {gpu: false}`). On a cluster
  # with no GPU partition the checkbox only ever produces a --gres=gpu:1 submit failure.
  fcfg     = site['form'] || {}
  show_gpu = fcfg.key?('gpu') ? !!fcfg['gpu'] : true
  root_tmpl   = gcfg['root_path'] || '/groups/{group_dir}/aba'
  strip       = gcfg['strip_suffix'].to_s                 # strip a site suffix: unix group → folder
  ui          = site['ui_text'] || {}
  markers     = ['.aba-workspace', '.bundle', '.envs']    # == aba_preflight OURS_MARKERS
  me          = ENV['USER'] || (Etc.getpwuid(Process.uid).name rescue 'user')
  myhome      = ENV['HOME'] || (Dir.home rescue '/tmp')

  # {group_dir} = on-disk folder name (strip the site suffix); {group} = unix group name.
  gdir     = ->(g) { (strip != '' && g.end_with?(strip)) ? g[0...-strip.length] : g }
  grp_root = ->(g) { root_tmpl.gsub('{group_dir}', gdir.call(g)).gsub('{group}', g) }
  # The user's session $ABA_HOME for a group, mirroring aba_preflight: <state_dir>/.home/.aba.
  state_tmpl = ucfg['state_dir'] || (myhome + '/.aba/state')
  aba_home = ->(g) {
    sd = state_tmpl.gsub('{group_dir}', gdir.call(g)).gsub('{group}', g)
                   .gsub('{user}', me).gsub('{home}', myhome)
    File.join(sd, '.home', '.aba')
  }
  # A personal credential OVERRIDE is present iff the app persisted one to $ABA_HOME
  # (Settings → config.env key/token, or subscription → oauth.json, or legacy json).
  has_personal = ->(g) {
    h = aba_home.call(g)
    (File.exist?(File.join(h, 'oauth.json')) ||
     File.exist?(File.join(h, 'credentials.json')) ||
     (File.exist?(File.join(h, 'config.env')) &&
      File.read(File.join(h, 'config.env')) =~ /ANTHROPIC_API_KEY|CLAUDE_CODE_OAUTH_TOKEN/)) ? true : false
  } rescue ->(g) { false }

  user_groups = (Process.groups + [Process.gid]).uniq.map { |gid|
    (Etc.getgrgid(gid).name rescue nil) }.compact.sort     # the user's own groups (primary + supplementary)
  # ENROLLED = the group's on-disk folder (strip suffix) carries an ABA marker.
  enrolled = gcfg['enabled'] ? user_groups.select { |g|
    markers.any? { |m| (File.exist?(File.join(grp_root.call(g), m)) rescue false) } } : []
  lab_opts = enrolled.map { |g| ["#{g}  ✓", g] }            # VALUE stays the unix group name
  if lab_opts.empty?
    contact = ui['enroll_contact'] || 'your ABA admin'
    lab_opts = [["— no enrolled groups (contact #{contact} to join the ABA pilot)", ""]]
  end
  # Show the "reset to the group credential" checkbox ONLY when a personal override exists
  # (for some enrolled group). Fail-safe: any probe error → hidden (never breaks the form).
  show_reset = (enrolled.any? { |g| has_personal.call(g) } rescue false)

  # Version line (small grey, under the Lab field). At FORM-render time we can only show the
  # deployment's CURRENT release + the published env stacks (read straight off the FS) — the
  # session CARD later shows the release the session actually PINNED. Fail-safe: any error → ''.
  ver_bits = []
  begin
    rr = ((site['image'] || {})['release_root'])
    if rr
      rel = (File.basename(File.realpath(File.join(rr, 'current'))) rescue nil)
      ver_bits << "release #{rel}" if rel
    end
  rescue; end
  begin
    pt = ((site['envs'] || {})['publish_tree'])
    if pt
      cat = YAML.safe_load(File.read(File.join(pt, 'catalog.json')))
      names = ((cat || {})['envs'] || {}).map { |n, i| "#{n} #{(i['latest'] || '').to_s.rpartition('-').first}" }
      ver_bits << "envs: #{names.join(', ')}" unless names.empty?
    end
  rescue; end
  ver_line = ver_bits.empty? ? '' : ('aba ' + ver_bits.join(' · '))
  ver_html = ver_line.empty? ? '' : "<br><small style='color:#888'>#{ver_line}</small>"
  # Render the version as a FOOTER: hang it off the help of the LAST field in the form order
  # below, so it sits at the bottom of the card (not mid-form). aba_lab is always first, so it
  # never carries it. vf.(field) returns the version HTML only for the last field, else ''.
  form_fields = ['aba_lab', 'aba_instance']
  form_fields << 'has_gpu' if show_gpu
  form_fields << 'reset_credential' if show_reset
  last_field = form_fields.last
  vf = ->(f) { last_field == f ? ver_html : '' }
-%>
---
cluster: "dev-cluster"
form:
  - aba_lab
  - aba_instance
<%- if show_gpu -%>
  - has_gpu
<%- end -%>
<%- if show_reset -%>
  - reset_credential
<%- end -%>
attributes:
  aba_instance:
    widget: "select"
    label: "Instance"
    help: "Light = 1 core; Heavy = 10 cores.<%= vf.call('aba_instance') %>"
    options:
      - ["Light — 1 core", "light"]
      - ["Heavy — 10 cores", "heavy"]
  aba_lab:
    widget: "select"
    label: "Lab"
    help: "<%= ui['form_intro'] || 'Your enrolled ABA groups (✓). Group not listed? Ask your admin to enroll it.' %><%= vf.call('aba_lab') %>"
    options:
<%- lab_opts.each do |label, val| -%>
      - ["<%= label %>", "<%= val %>"]
<%- end -%>
  has_gpu:
    widget: "check_box"
    label: "Request a GPU"
    help: "<%= vf.call('has_gpu') %>"
  # No credential field: the group credential (set up in the group's ABA folder) is used by
  # default, and a user connects their OWN key/subscription in-session via Settings → Agent.
  # This box (shown only when you already have a personal credential saved) discards it so the
  # session uses the lab's shared credential instead. Unchecked = keep using your personal one.
  reset_credential:
    widget: "check_box"
    label: "Use the group credential (clear my personal key/subscription)"
    help: "You have a personal credential saved from a previous session. Check to discard it and use the lab's shared credential this session.<%= vf.call('reset_credential') %>"
