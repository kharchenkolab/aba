<%-
  # ── Preflight at form-render time, driven by /cluster/aba/site.yaml ──
  # List ONLY the launching user's own unix groups that are ENROLLED in ABA —
  # i.e. /groups/<group>/aba carries the .aba-workspace marker (the SAME signal
  # aba_preflight gates on). Unenrolled groups are omitted so a user can't launch
  # a session preflight would just block. All paths come from site.yaml.
  require 'yaml'; require 'etc'
  # Deployment share root. deploy.sh rewrites this default for the site; an exported
  # ABA_SITE_CONFIG still wins.
  site_default = '/cluster/aba/site.yaml'
  site = (YAML.safe_load(File.read(ENV['ABA_SITE_CONFIG'] || site_default)) rescue nil) || {}
  gcfg = (site['scopes'] || {})['group'] || {}
  # GPU field — shown unless the site disables it (`form: {gpu: false}`). On a cluster
  # with no GPU partition the checkbox only ever produces a --gres=gpu:1 submit failure.
  fcfg     = site['form'] || {}
  show_gpu = fcfg.key?('gpu') ? !!fcfg['gpu'] : true
  root_tmpl   = gcfg['root_path'] || '/groups/{group}/aba'
  groups_root = root_tmpl.split('/{group}').first         # e.g. /groups
  ui          = site['ui_text'] || {}
  markers     = ['.aba-workspace', '.bundle', '.envs']    # == aba_preflight OURS_MARKERS

  user_groups = (Process.groups + [Process.gid]).uniq.map { |gid|
    (Etc.getgrgid(gid).name rescue nil) }.compact.sort     # the user's own groups (primary + supplementary)
  enrolled = gcfg['enabled'] ? user_groups.select { |g|
    markers.any? { |m| File.exist?(File.join(groups_root, g, 'aba', m)) } } : []
  lab_opts = enrolled.map { |g| ["#{g}  ✓", g] }
  if lab_opts.empty?
    contact = ui['enroll_contact'] || 'your ABA admin'
    lab_opts = [["— no enrolled groups (contact #{contact} to join the ABA pilot)", ""]]
  end
-%>
---
cluster: "dev-cluster"
form:
  - aba_lab
  - aba_instance
<%- if show_gpu -%>
  - has_gpu
<%- end -%>
  - aba_token
attributes:
  aba_instance:
    widget: "select"
    label: "Instance"
    help: "Light = 1 core; Heavy = 10 cores."
    options:
      - ["Light — 1 core", "light"]
      - ["Heavy — 10 cores", "heavy"]
  aba_lab:
    widget: "select"
    label: "Lab"
    help: "<%= ui['form_intro'] || 'Your enrolled ABA groups (✓). Group not listed? Ask your admin to enroll it.' %>"
    options:
<%- lab_opts.each do |label, val| -%>
      - ["<%= label %>", "<%= val %>"]
<%- end -%>
  has_gpu:
    widget: "check_box"
    label: "Request a GPU"
  aba_token:
    widget: "text_field"
    label: "Anthropic API key or OAuth token"
    value: ""
    help: "Paste an API key (sk-ant-api…) or a Claude Code OAuth token (sk-ant-oat…, from `claude setup-token`) to enable chat — auto-detected. Leave blank to use a saved/lab credential. The UI loads either way."
