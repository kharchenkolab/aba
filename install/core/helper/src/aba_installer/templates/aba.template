#!/usr/bin/env bash
# ABA launcher — installed by the ABA installer at $ABA_HOME/bin/aba (under
# the ABA home so the install stays self-contained). Sources config.env so the
# backend boots with the API key + paths the installer captured.
#
# Auto-generated. Do not edit by hand — re-run the installer to update.

set -euo pipefail

export ABA_HOME="@@ABA_HOME@@"
export ABA_RUNTIME_DIR="@@ABA_RUNTIME_DIR@@"
ABA_ENV="@@ABA_ENV@@"
ABA_REPO="@@ABA_REPO@@"
ABA_PORT="@@ABA_PORT@@"

# Source persisted creds + any extras. The installer wrote this at mode 0600.
if [[ -f "$ABA_HOME/config.env" ]]; then
  set -a
  # shellcheck disable=SC1091
  . "$ABA_HOME/config.env"
  set +a
fi

mkdir -p "$ABA_HOME/logs"

# Match ONLY this install's backend, by its unique --app-dir. A bare
# "uvicorn main:app" match is machine-global: a stale uvicorn from a crashed or
# deleted install would make `up` think we're already running and silently
# no-op, leaving "connection refused". (pgrep/pkill exclude their own pid.)
BACKEND_MATCH="uvicorn main:app --app-dir $ABA_REPO/aba/backend"

case "${1:-up}" in
  up)
    if pgrep -f "$BACKEND_MATCH" > /dev/null 2>&1; then
      echo "ABA is already running on http://127.0.0.1:$ABA_PORT"
      exit 0
    fi
    nohup "$ABA_ENV/bin/uvicorn" main:app \
        --app-dir "$ABA_REPO/aba/backend" \
        --host 127.0.0.1 --port "$ABA_PORT" \
        > "$ABA_HOME/logs/backend.log" 2>&1 &
    echo "ABA up on http://127.0.0.1:$ABA_PORT (pid $!)"
    ;;
  stop)
    pkill -f "$BACKEND_MATCH" 2>/dev/null || true
    # Wait for it to actually exit — pkill only signals. Without this, a
    # follow-up `up` (or the Control panel's Restart) races the still-dying
    # process, sees it "already running", and no-ops, leaving ABA down.
    for _ in $(seq 1 20); do
      pgrep -f "$BACKEND_MATCH" > /dev/null 2>&1 || break
      sleep 0.25
    done
    if pgrep -f "$BACKEND_MATCH" > /dev/null 2>&1; then
      pkill -9 -f "$BACKEND_MATCH" 2>/dev/null || true
    fi
    echo "ABA stopped."
    ;;
  status)
    if pgrep -f "$BACKEND_MATCH" > /dev/null 2>&1; then
      pid=$(pgrep -f "$BACKEND_MATCH" | head -1)
      echo "Running (pid $pid) on http://127.0.0.1:$ABA_PORT"
    else
      echo "(not running)"
    fi
    ;;
  logs)
    tail -f "$ABA_HOME/logs/backend.log"
    ;;
  update|doctor|auth|hpc-config)
    # CLI path — pull latest / diagnose / sign in / write an hpc.yaml override via
    # the headless installer.
    # Works on a server with no browser (the old open/curl were mac-only). The
    # mac tray's Update button still uses the helper's /api/update for live UI.
    HELPER_PY="$ABA_HOME/installer/venv/bin/python"
    if [ -x "$HELPER_PY" ]; then
      exec "$HELPER_PY" -m aba_installer.cli "$@"
    else
      echo "installer helper not found at $HELPER_PY — re-run the installer to restore it"
      exit 1
    fi
    ;;
  uninstall)
    "$0" stop
    rm -rf "$ABA_HOME"
    # Launcher lives under $ABA_HOME (removed above); also clear any legacy
    # ~/bin or --global copies from older installs.
    rm -f "$HOME/bin/aba" /usr/local/bin/aba 2>/dev/null || true
    echo "Uninstalled. Runtime files preserved at $ABA_HOME (if any remain)."
    ;;
  *)
    cat <<EOF
usage: aba <command>
  up         Start ABA in the background
  stop       Stop ABA
  status     Is it running?
  logs       Tail the backend log
  update     Pull the latest code + recipes, refresh env, rebuild the UI
  doctor     Diagnose this install (env, frontend, recipes, credential, Slurm)
  auth       Set a credential (Sign in with Claude / --token / --api-key)
  hpc-config Write an optional hpc.yaml override (partitions/QOS/account are
             otherwise discovered live); --print to preview without writing
  uninstall  Remove ABA from this machine
EOF
    exit 2
    ;;
esac
