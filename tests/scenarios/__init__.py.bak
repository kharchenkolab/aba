"""Chat scenario fixtures — canonical user prompts + mocked tool
responses + assertions on what the model should do.

Each scenario drives a real LLMRuntime end-to-end with a MOCK tool
executor (so no GEO downloads, no Python execution, no SQL writes
happen). The model's choices are real; everything around it is
canned. That lets us:

  - Iterate on tool descriptions + system prompt without bothering
    the user.
  - Catch dispatch-shape regressions (skill-name-as-tool bug,
    recipe-not-followed bug, _StreamCompleted gap) before they ever
    reach a live session.
  - Run the same suite against multiple runtimes (Anthropic Opus,
    Anthropic Haiku, local Qwen3) and compare.

This module exports SCENARIOS — a list[Scenario] discovered by the
test runner.
"""
from __future__ import annotations

from dataclasses import dataclass, field
from typing import Any, Callable


# A tool-mock returns the canned result the executor should hand back
# to the model. It receives the actual `input` the model chose so a
# mock for `Skill` can branch on `skill` name.
ToolMock = Callable[[dict], dict]


@dataclass
class Scenario:
    """One canonical chat exchange.

    user_prompt: what the user typed.
    tool_mocks: dispatch table — tool name → ToolMock. Tools not in
                this dict, AND not in `use_real_tool`, get a generic
                `{"status":"ok"}` reply so the model can keep going.
    use_real_tool: set of tool names to dispatch via the REAL aba
                tool executor (bio MCP) instead of a mock. Use for
                tools whose argument semantics matter (search_skills'
                `domain` filter, ensure_capability's PyPI vs GitHub
                routing, …) — mocking those teaches the suite to lie.
                Reserve mocks for tools with real side effects
                (run_python, register_dataset, …).
    assertions: list of named predicates over the recorded tool call
                sequence. The driver evaluates each and reports pass /
                fail; failed assertions don't abort the turn so we get
                the full picture.
    max_turns:  cap on outer-loop iterations so a stuck model doesn't
                bill forever.
    """
    name:           str
    user_prompt:    str
    tool_mocks:     dict[str, ToolMock] = field(default_factory=dict)
    use_real_tool:  frozenset[str]      = field(default_factory=frozenset)
    assertions:     list["Assertion"]   = field(default_factory=list)
    max_turns:      int = 4


@dataclass
class Assertion:
    """A check the driver evaluates against the recorded tool calls.

    The predicate receives the list[(tool_name, tool_input)] in
    chronological order and returns (passed: bool, detail: str).
    `detail` lands in the failure report whether it passed or not, so
    a green test still tells you what the assertion was about.
    """
    name:      str
    predicate: Callable[[list[tuple[str, dict]]], tuple[bool, str]]


# ── Canned recipe bodies + skill catalogs (small but realistic) ────


_FETCH_GEO_RECIPE_BODY = """# fetch-geo-processed-matrices

Download processed/supplementary files (count matrices) for a GEO
series or sample. Works for 10x mtx triplets, h5/h5ad bundles, or
per-sample count tables.

## When to use
You have a KNOWN GEO accession (GSE…, GSM…) and you want the
matrices on disk. Returns nothing if the user has not yet given you
an accession.

## Step 1 — Download

```python
import urllib.request, os
os.makedirs('./geo_data', exist_ok=True)
acc = "$ARGUMENTS"
soft_url = f"https://www.ncbi.nlm.nih.gov/geo/query/acc.cgi?targ=self&acc={acc}&form=text&view=quick"
# … parses SOFT and downloads supplementary files …
```

## Step 2 — Register

```python
register_dataset(title=f"{acc} counts", path="./geo_data")
```

## Gotchas
- Don't ask the user to upload data when you have a GEO accession —
  the recipe downloads it for you.
- Always run the download Python BEFORE checking list_data_files.
"""


_GEO_SEARCH_RESULT = {
    "skills": [
        {"name": "fetch-geo-processed-matrices",
         "description": "Download processed/supplementary files for a "
                        "GEO series or sample."},
        {"name": "scrna-geo-pipeline",
         "description": "End-to-end scRNA pipeline from a GEO "
                        "accession to annotated clusters."},
        {"name": "query-geo",
         "description": "Query the GEO database for a study or sample."},
    ],
}


def _skill_mock_for(skill_to_body: dict[str, str]) -> ToolMock:
    """Build a Skill(...) mock that branches on the `skill` arg."""
    def _mock(input_: dict) -> dict:
        name = input_.get("skill") or ""
        body = skill_to_body.get(name)
        if body is None:
            return {"status": "error", "content":
                    f"unknown skill: {name!r}"}
        return {"status": "ok", "name": name,
                "description": body.split("\n", 1)[0],
                "body": body}
    return _mock


# ── Assertion helpers ──────────────────────────────────────────────


def _first_tool_is(target: str | tuple[str, ...]):
    targets = (target,) if isinstance(target, str) else target
    def _p(calls):
        if not calls:
            return False, "no tools were called"
        return calls[0][0] in targets, \
            f"first tool was {calls[0][0]!r}, expected one of {targets}"
    return _p


def _no_skill_called_as_tool(calls):
    """The headline regression: skill names must never appear as tool
    names. If the model emits `fetch-geo-processed-matrices(...)` as a
    bare tool name we caught the Skill-as-tool bug."""
    skill_like = {"fetch-geo-processed-matrices", "scrna-geo-pipeline",
                  "scrna-qc-clustering-v2", "query-geo"}
    bad = [n for n, _ in calls if n in skill_like]
    return (not bad), (
        f"called skill names as tools: {bad}" if bad
        else "no skill-as-tool calls")


def _after_skill_run_python(calls):
    """Once the model has fetched a recipe via Skill, the next move
    SHOULD execute the recipe — run_python or run_r. If the model
    instead checks list_data_files / asks the user to upload, the
    recipe-not-followed bug fired."""
    saw_skill = False
    for n, _ in calls:
        if saw_skill and n in ("run_python", "run_r"):
            return True, f"ran code after Skill (the {n!r} call)"
        if saw_skill and n in ("list_data_files",):
            return False, (
                f"called {n!r} after fetching recipe — the recipe was "
                "supposed to be RUN, not bypassed by asking the user "
                "to upload data")
        if n == "Skill":
            saw_skill = True
    return (not saw_skill), \
        ("Skill never fired (no recipe to follow up on)" if not saw_skill
         else "ran no code after Skill")


def _search_actually_found_geo_recipe(calls):
    """Was `search_skills` actually useful — i.e., did any call cause
    the model's NEXT move to be a `Skill(skill="…")` invocation? If
    the model searched, got nothing useful back, and gave up — that's
    a retrieval-quality failure, not a model failure."""
    saw_search = False
    for n, args in calls:
        if n == "search_skills":
            saw_search = True
            continue
        if saw_search and n == "Skill":
            sk = (args.get("skill") or "")
            if "geo" in sk.lower() or "fetch" in sk.lower():
                return True, (f"after search, model invoked "
                              f"Skill(skill={sk!r}) — search was useful")
            else:
                return False, (f"after search, model invoked "
                               f"Skill(skill={sk!r}) — unrelated to GEO; "
                               "retrieval surfaced wrong recipe")
    if saw_search:
        return False, ("model searched but never followed up with "
                       "Skill(...) — search returned nothing it could act on")
    return True, "no search occurred (scenario didn't reach search step)"


def _retries_without_domain(calls):
    """If the model called search_skills multiple times and the FIRST
    call passed a `domain` filter, the SECOND call must drop it.
    Otherwise we're watching the prj_52ec6529 retry-with-domain loop."""
    searches = [(i, args) for i, (n, args) in enumerate(calls)
                if n == "search_skills"]
    if len(searches) < 2:
        return True, "only one search_skills call (no retry to validate)"
    first_had_domain = bool(searches[0][1].get("domain"))
    if not first_had_domain:
        return True, "first search had no domain filter"
    second_has_domain = bool(searches[1][1].get("domain"))
    if second_has_domain:
        return False, ("second search_skills retry STILL has a "
                       "`domain` filter — model is looping with the "
                       "same useless argument")
    return True, "retry correctly dropped the domain filter"


def _used_present_plan_before_execution(calls):
    """plan-first protocol: before run_python on a multi-step task,
    the model should call present_plan. Treat the absence as a soft
    failure (not all tasks need a plan) — it's only enforced for
    scenarios that flag this."""
    saw_plan = False
    for n, _ in calls:
        if n == "present_plan":
            saw_plan = True
        if n in ("run_python", "run_r") and not saw_plan:
            return False, f"ran {n!r} before present_plan"
    return True, "plan-first respected (or no execution happened)"


# ── The scenarios ──────────────────────────────────────────────────


SCENARIOS: list[Scenario] = [
    Scenario(
        name="geo_lookup_dispatches_via_Skill_not_bare_name",
        user_prompt="show me the sample table for GSE192391 on GEO",
        # Use REAL search_skills + Skill so we catch quirks like the
        # `domain` filter (live bug in prj_52ec6529: model added
        # domain='bioinformatics' which returned [] every time).
        use_real_tool=frozenset({"search_skills", "Skill"}),
        tool_mocks={
            "list_data_files": lambda i: {
                "files": [],
                "message": ("This project has no datasets yet. "
                            "Recipes that download from a registry "
                            "(GEO, SRA, …) will populate the dir."),
            },
        },
        assertions=[
            Assertion("no_skill_called_as_tool",
                      _no_skill_called_as_tool),
            Assertion("first_tool_is_search_or_Skill",
                      _first_tool_is(("search_skills", "Skill"))),
            # If the model added a domain filter that emptied results,
            # the SECOND search must NOT keep using it (otherwise we
            # loop). Encoded inline.
            Assertion(
                "retries_without_domain_on_empty",
                lambda calls: _retries_without_domain(calls),
            ),
        ],
        max_turns=4,
    ),
    Scenario(
        name="search_skills_finds_geo_recipe_from_natural_language",
        user_prompt="show me the sample table for GSE192391 on GEO",
        use_real_tool=frozenset({"search_skills", "Skill"}),
        tool_mocks={
            # We don't care what happens after Skill; cap with a stub.
            "list_data_files": lambda i: {"files": [], "message": "empty"},
            "run_python":      lambda i: {"stdout": "(stub)", "returncode": 0},
            "fetch_url":       lambda i: {"status": "ok", "path": "/tmp/x"},
        },
        assertions=[
            Assertion("search_actually_found_geo_recipe",
                      _search_actually_found_geo_recipe),
        ],
        max_turns=3,
    ),
    Scenario(
        name="recipe_loaded_then_run_python_not_list_data_files",
        user_prompt="show me the sample table for GSE192391 on GEO",
        use_real_tool=frozenset({"search_skills", "Skill"}),
        tool_mocks={
            "list_data_files": lambda i: {
                "files": [],
                "message": "no data yet — recipes will download.",
            },
            "run_python":   lambda i: {
                "stdout": "downloaded 6 files to ./geo_data",
                "stderr": "", "returncode": 0,
            },
            "register_dataset": lambda i: {
                "ok": True, "id": "dat_mock"},
        },
        assertions=[
            Assertion("after_skill_run_python", _after_skill_run_python),
            Assertion("no_skill_called_as_tool", _no_skill_called_as_tool),
        ],
        max_turns=5,
    ),
]


