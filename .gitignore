# Pre-2026-05-31 runtime lived under backend/. It now lives under
# $ABA_RUNTIME_DIR (default /workspace/aba-runtime/) which is OUTSIDE the
# source tree — so the cleanup below is a safety net for fresh clones that
# might override ABA_RUNTIME_DIR back into backend/, not a daily-driver rule.
backend/aba.db
backend/artifacts/
backend/data/
backend/envs/
# Also catches the symlink form: backend/envs -> $ABA_RUNTIME_DIR/envs
backend/envs
backend/projects/
backend/refs/
backend/work/
backend/knowhow/context_policy/
Rplots.pdf
frontend/dist/

# Vendored BioMNI reference clone (kept as a working copy for code reading)
/biomni/

# E2E test outputs
tests/e2e/screenshots/

# Large local-only assets (kept out of git)
misc/ui3/*.png
eval/audits/vendor/
